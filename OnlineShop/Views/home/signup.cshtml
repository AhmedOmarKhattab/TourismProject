@model OnlineShop.Models.customer
@{
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

@section head {
    <style>
        .signup-page {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        /* ── LEFT PANEL ── */
        .signup-left {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 60px 50px;
            overflow: hidden;
            background: var(--navy-mid);
        }

            .signup-left::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: url('/files/SiteImages/Riyadh.jpg');
                background-size: cover;
                background-position: center;
                filter: brightness(0.2);
            }

            .signup-left::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(160deg, rgba(10,22,40,0.65) 0%, rgba(201,168,76,0.07) 100%);
            }

        .deco-circle {
            position: absolute;
            border-radius: 50%;
            border: 1px solid rgba(201,168,76,0.1);
            z-index: 1;
        }

        .deco-1 {
            width: 360px;
            height: 360px;
            bottom: -90px;
            left: -90px;
        }

        .deco-2 {
            width: 220px;
            height: 220px;
            top: 30px;
            right: -60px;
        }

        .deco-3 {
            width: 120px;
            height: 120px;
            top: 50%;
            left: 40px;
        }

        .left-content {
            position: relative;
            z-index: 2;
            text-align: center;
        }

        .brand-logo-wrap {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            border: 2px solid var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            background: rgba(10,22,40,0.5);
            backdrop-filter: blur(6px);
        }

            .brand-logo-wrap img {
                width: 70px;
                height: 70px;
                border-radius: 50%;
                object-fit: cover;
            }

        .left-title {
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--white);
            margin-bottom: 10px;
            line-height: 1.2;
        }

            .left-title span {
                color: var(--gold);
            }

        .left-subtitle {
            font-size: 0.92rem;
            color: var(--text-muted);
            line-height: 1.85;
            max-width: 320px;
            margin: 0 auto 36px;
        }

        .steps-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
            max-width: 300px;
            margin: 0 auto;
            text-align: right;
        }

        .step-item {
            display: flex;
            align-items: center;
            gap: 14px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(201,168,76,0.15);
            border-radius: 8px;
            padding: 12px 16px;
        }

        .step-num {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, var(--gold), var(--gold-dark));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--navy);
            flex-shrink: 0;
        }

        .step-item span {
            font-size: 0.84rem;
            color: rgba(240,234,214,0.85);
            font-weight: 500;
        }

        /* ── RIGHT PANEL ── */
        .signup-right {
            background: var(--navy);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 50px 50px;
            overflow-y: auto;
        }

        .signup-box {
            width: 100%;
            max-width: 440px;
        }

        .signup-box-header {
            margin-bottom: 30px;
        }

            .signup-box-header .label {
                font-size: 0.72rem;
                font-weight: 700;
                letter-spacing: 3px;
                text-transform: uppercase;
                color: var(--gold);
                display: block;
                margin-bottom: 10px;
            }

            .signup-box-header h2 {
                font-size: 1.9rem;
                font-weight: 900;
                color: var(--white);
                line-height: 1.25;
            }

            .signup-box-header p {
                font-size: 0.86rem;
                color: var(--text-muted);
                margin-top: 8px;
                line-height: 1.7;
            }

        /* fields */
        .field-group {
            margin-bottom: 16px;
        }

        .field-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: rgba(240,234,214,0.8);
            margin-bottom: 7px;
            letter-spacing: 0.3px;
        }

        .field-wrap {
            position: relative;
        }

            .field-wrap i {
                position: absolute;
                top: 50%;
                right: 15px;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 0.88rem;
                pointer-events: none;
                transition: color 0.2s ease;
            }

            .field-wrap input {
                width: 100%;
                background: rgba(255,255,255,0.04);
                border: 1.5px solid rgba(255,255,255,0.1);
                border-radius: 8px;
                padding: 12px 42px 12px 14px;
                color: var(--white);
                font-family: 'Cairo', sans-serif;
                font-size: 0.9rem;
                transition: all 0.25s ease;
                outline: none;
                direction: rtl;
            }

                .field-wrap input::placeholder {
                    color: var(--text-muted);
                }

                .field-wrap input:focus {
                    border-color: var(--gold);
                    background: rgba(201,168,76,0.05);
                    box-shadow: 0 0 0 3px rgba(201,168,76,0.1);
                }

            .field-wrap:focus-within i {
                color: var(--gold);
            }

        /* two-col row */
        .fields-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        /* password strength */
        .password-hint {
            font-size: 0.74rem;
            color: var(--text-muted);
            margin-top: 5px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .password-hint i {
                color: rgba(201,168,76,0.5);
                font-size: 0.68rem;
            }

        /* submit */
        .btn-signup {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
            border: none;
            border-radius: 8px;
            color: var(--navy);
            font-family: 'Cairo', sans-serif;
            font-size: 0.98rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 6px;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-signup:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 28px rgba(201,168,76,0.4);
            }

        /* divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 14px;
            margin: 20px 0;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: rgba(255,255,255,0.08);
            }

            .divider span {
                font-size: 0.74rem;
                color: var(--text-muted);
                white-space: nowrap;
            }

        /* social */
        .social-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 24px;
        }

        .btn-social {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1.5px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.03);
            color: rgba(240,234,214,0.8);
            font-family: 'Cairo', sans-serif;
            font-size: 0.84rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.25s ease;
        }

            .btn-social:hover {
                background: rgba(255,255,255,0.07);
                border-color: rgba(255,255,255,0.2);
                color: var(--white);
                text-decoration: none;
            }

            .btn-social .fa-facebook {
                color: #1877F2;
            }

            .btn-social .fa-instagram {
                color: #E1306C;
            }

        /* login prompt */
        .login-prompt {
            text-align: center;
            margin-top: 20px;
            font-size: 0.86rem;
            color: var(--text-muted);
        }

            .login-prompt a {
                color: var(--gold-light);
                text-decoration: none;
                font-weight: 600;
                transition: color 0.2s ease;
            }

                .login-prompt a:hover {
                    color: var(--gold);
                }

        /* terms note */
        .terms-note {
            font-size: 0.74rem;
            color: var(--text-muted);
            text-align: center;
            margin-top: 14px;
            line-height: 1.7;
        }

            .terms-note a {
                color: var(--gold);
                text-decoration: none;
            }

        /* responsive */
        @@media (max-width: 900px) {
            .signup-page {
                grid-template-columns: 1fr;
            }

            .signup-left {
                display: none;
            }

            .signup-right {
                padding: 40px 24px;
                min-height: 100vh;
            }
        }

        @@media (max-width: 420px) {
            .fields-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="signup-page">

    <!-- ── BRANDING PANEL ── -->
    <div class="signup-left">
        <div class="deco-circle deco-1"></div>
        <div class="deco-circle deco-2"></div>
        <div class="deco-circle deco-3"></div>

        <div class="left-content">
            <div class="brand-logo-wrap">
                <img src="~/files/SiteImages/logo.PNG" alt="BlueSky Logo">
            </div>

            <h1 class="left-title">انضم إلى<br><span>بلو سكاى</span></h1>
            <p class="left-subtitle">
                سجّل حسابك الآن واستمتع بتجربة سفر فريدة مع أفضل الرحلات الداخلية والخارجية
            </p>

            <div class="steps-list">
                <div class="step-item">
                    <div class="step-num">١</div>
                    <span>أنشئ حسابك في دقيقة واحدة</span>
                </div>
                <div class="step-item">
                    <div class="step-num">٢</div>
                    <span>تصفح مئات الرحلات المتاحة</span>
                </div>
                <div class="step-item">
                    <div class="step-num">٣</div>
                    <span>احجز وادفع بأمان تام</span>
                </div>
                <div class="step-item">
                    <div class="step-num">٤</div>
                    <span>استمتع برحلتك بلا قلق</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── FORM PANEL ── -->
    <div class="signup-right">
        <div class="signup-box">

            <div class="signup-box-header">
                <span class="label">ابدأ رحلتك</span>
                <h2>إنشاء حساب جديد</h2>
                <p>أدخل بياناتك لإنشاء حسابك مجاناً</p>
            </div>

            @using (Html.BeginForm("signup", "Home", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <div class="fields-row">
                    <div class="field-group">
                        <label class="field-label" for="name">الاسم الكامل</label>
                        <div class="field-wrap">
                            <input id="name" name="name" type="text" placeholder="محمد أحمد" required>
                            <i class="fas fa-user"></i>
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label" for="phone">رقم الهاتف</label>
                        <div class="field-wrap">
                            <input id="phone" name="phone" type="text" placeholder="01xxxxxxxxx" required>
                            <i class="fas fa-phone"></i>
                        </div>
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label" for="email">البريد الإلكتروني</label>
                    <div class="field-wrap">
                        <input id="email" name="email" type="email" placeholder="example@email.com" required autocomplete="email">
                        <i class="fas fa-envelope"></i>
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label" for="adress">العنوان</label>
                    <div class="field-wrap">
                        <input id="adress" name="adress" type="text" placeholder="المدينة، الحي" required>
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label" for="password">كلمة المرور</label>
                    <div class="field-wrap">
                        <input id="password" name="password" type="password" placeholder="••••••••" required autocomplete="new-password">
                        <i class="fas fa-lock"></i>
                    </div>
                    <div class="password-hint">
                        <i class="fas fa-info-circle"></i>
                        يُنصح باستخدام 8 أحرف على الأقل تشمل أرقاماً ورموزاً
                    </div>
                </div>

                <button type="submit" class="btn-signup">
                    <i class="fas fa-user-plus"></i>
                    إنشاء الحساب
                </button>
            }

            <div class="divider"><span>أو سجّل عبر</span></div>

            <div class="social-row">
                <a href="https://www.facebook.com/YourPage" target="_blank" rel="noopener noreferrer" class="btn-social">
                    <i class="fab fa-facebook"></i> فيسبوك
                </a>
                <a href="https://www.instagram.com/YourPage" target="_blank" rel="noopener noreferrer" class="btn-social">
                    <i class="fab fa-instagram"></i> انستغرام
                </a>
            </div>

            <div class="login-prompt">
                لديك حساب بالفعل؟
                <a href="login">تسجيل الدخول</a>
            </div>

            <p class="terms-note">
                بإنشاء حساب فأنت توافق على
                <a href="#">شروط الاستخدام</a> و <a href="#">سياسة الخصوصية</a>
            </p>

        </div>
    </div>

</div>
