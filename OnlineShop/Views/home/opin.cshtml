@model OnlineShop.Models.allproject

@{
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
}
<br /><br /><br />
<h2 align="center" style="color:black">أكتب رأيك</h2>

<div class="bg-white mb-3" style="padding: 30px;" dir="rtl">
    @using (Html.BeginForm("addopin", "Home", FormMethod.Post, new { name = "ss", enctype = "multipart/form-data" }))
    {
        @Html.HiddenFor(x=>x.email)
        <form dir="rtl">
            <div class="form-group">
                <p align="right">اسمك  </p>
                <input type="text" class="form-control" name="name" id="name" required>
            </div>
           
            <div class="form-group">
                <p align="right">تقييمك  </p>
                <textarea cols="50" name="opin1" type="text" class="form-control" id="website" required></textarea>
            </div>
         

            <div class="form-group mb-0">
                <input type="submit" value="ارسال  البيانات"
                       class="btn btn-danger">
            </div>
        </form>
    }
</div>

