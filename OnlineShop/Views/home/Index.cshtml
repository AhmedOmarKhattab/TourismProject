@model OnlineShop.Models.allproject

@{
    Layout = "~/Views/Shared/_LayoutHome.cshtml";
}

@section head {
    <style>
    /* ══ HERO ══ */
    .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: var(--navy);
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background-image: url('/files/SiteImages/slide1.jpg');
        background-size: cover;
        background-position: center;
        filter: brightness(0.35);
        transform: scale(1.05);
        animation: heroZoom 14s ease-in-out infinite alternate;
    }

    @@keyframes heroZoom {
        from { transform: scale(1.05); }
        to   { transform: scale(1.12); }
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(10,22,40,0.85) 0%, rgba(10,22,40,0.3) 60%, transparent 100%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 60px;
        padding-top: 100px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(201,168,76,0.15);
        border: 1px solid rgba(201,168,76,0.4);
        color: var(--gold-light);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 2px;
        padding: 7px 18px;
        border-radius: 50px;
        margin-bottom: 28px;
        animation: fadeUp 0.8s ease forwards;
    }

    .hero-badge i { font-size: 0.65rem; }

    .hero-title {
        font-size: clamp(2.4rem, 5vw, 4.2rem);
        font-weight: 900;
        color: var(--white);
        line-height: 1.2;
        max-width: 720px;
        margin-bottom: 22px;
        animation: fadeUp 0.8s 0.15s ease both;
    }

    .hero-title span { color: var(--gold); }

    .hero-subtitle {
        font-size: 1.05rem;
        color: var(--text-muted);
        line-height: 1.8;
        max-width: 500px;
        margin-bottom: 40px;
        font-weight: 400;
        animation: fadeUp 0.8s 0.3s ease both;
    }

    .hero-actions {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        animation: fadeUp 0.8s 0.45s ease both;
    }

    .hero-scroll {
        position: absolute;
        bottom: 36px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.72rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        animation: bounce 2s infinite;
    }

    .hero-scroll i { font-size: 1.1rem; color: var(--gold); }

    .hero-stats {
        position: absolute;
        bottom: 60px;
        left: 60px;
        z-index: 2;
        display: flex;
        gap: 40px;
        animation: fadeUp 0.8s 0.6s ease both;
    }

    .stat-item { text-align: center; }
    .stat-num {
        font-size: 2rem;
        font-weight: 900;
        color: var(--gold);
        display: block;
        line-height: 1;
    }
    .stat-label {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 4px;
        letter-spacing: 1px;
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes bounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50%       { transform: translateX(-50%) translateY(6px); }
    }

    /* ══ TRIP TYPES ══ */
    .trips-section {
        padding: 100px 0;
        background: var(--navy-mid);
        position: relative;
        overflow: hidden;
    }

    .trips-section::before {
        content: '';
        position: absolute;
        top: -1px; right: 0; left: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }

    .section-header { text-align: center; margin-bottom: 60px; }

    .trips-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        max-width: 900px;
        margin: 0 auto;
    }

    .trip-card {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        height: 320px;
        cursor: pointer;
        text-decoration: none;
        display: block;
    }

    .trip-card img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .trip-card:hover img { transform: scale(1.08); }

    .trip-card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(10,22,40,0.92) 0%, rgba(10,22,40,0.2) 60%, transparent 100%);
        transition: background 0.3s ease;
    }

    .trip-card:hover .trip-card-overlay {
        background: linear-gradient(to top, rgba(10,22,40,0.96) 0%, rgba(10,22,40,0.4) 70%, transparent 100%);
    }

    .trip-card-content {
        position: absolute;
        bottom: 0; right: 0; left: 0;
        padding: 28px;
    }

    .trip-card-icon {
        width: 44px; height: 44px;
        background: var(--gold);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
        font-size: 1.1rem;
        color: var(--navy);
    }

    .trip-card-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--white);
        margin-bottom: 6px;
    }

    .trip-card-sub {
        font-size: 0.85rem;
        color: rgba(240,234,214,0.7);
        margin-bottom: 16px;
    }

    .trip-card-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--gold);
        font-size: 0.88rem;
        font-weight: 600;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s ease;
    }

    .trip-card:hover .trip-card-btn { border-color: var(--gold); }

    /* ══ SERVICES ══ */
    .services-section {
        padding: 100px 0;
        background: var(--navy);
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 20px;
    }

    .service-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(201,168,76,0.12);
        border-radius: 10px;
        padding: 32px 22px;
        text-align: center;
        transition: all 0.35s ease;
        position: relative;
        overflow: hidden;
    }

    .service-card::before {
        content: '';
        position: absolute;
        top: 0; right: 0; left: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--gold-dark), var(--gold-light));
        transform: scaleX(0);
        transition: transform 0.35s ease;
    }

    .service-card:hover {
        background: rgba(201,168,76,0.06);
        border-color: rgba(201,168,76,0.35);
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .service-card:hover::before { transform: scaleX(1); }

    .service-icon {
        width: 60px; height: 60px;
        background: linear-gradient(135deg, rgba(201,168,76,0.15), rgba(201,168,76,0.05));
        border: 1px solid rgba(201,168,76,0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 18px;
        font-size: 1.4rem;
        color: var(--gold);
        transition: all 0.3s ease;
    }

    .service-card:hover .service-icon {
        background: var(--gold);
        color: var(--navy);
        border-color: var(--gold);
    }

    .service-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--white);
        margin-bottom: 8px;
    }

    .service-desc {
        font-size: 0.8rem;
        color: var(--text-muted);
        line-height: 1.7;
    }

    /* ══ WHY US ══ */
    .why-section {
        padding: 100px 0;
        background: var(--navy-mid);
        position: relative;
    }

    .why-section::before {
        content: '';
        position: absolute;
        top: -1px; right: 0; left: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }

    .why-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .why-visual {
        position: relative;
    }

    .why-img-main {
        width: 100%;
        height: 460px;
        object-fit: cover;
        border-radius: 12px;
        display: block;
    }

    .why-img-badge {
        position: absolute;
        bottom: -24px;
        left: -24px;
        background: var(--gold);
        color: var(--navy);
        border-radius: 10px;
        padding: 22px 28px;
        text-align: center;
        box-shadow: 0 12px 30px rgba(201,168,76,0.35);
    }

    .why-img-badge .big-num {
        font-size: 2.6rem;
        font-weight: 900;
        display: block;
        line-height: 1;
    }

    .why-img-badge .small-text {
        font-size: 0.78rem;
        font-weight: 700;
        margin-top: 4px;
    }

    .why-features { display: flex; flex-direction: column; gap: 28px; }

    .why-feature {
        display: flex;
        gap: 18px;
        align-items: flex-start;
    }

    .why-feature-icon {
        width: 50px; height: 50px;
        flex-shrink: 0;
        background: rgba(201,168,76,0.1);
        border: 1px solid rgba(201,168,76,0.25);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: var(--gold);
    }

    .why-feature-text h4 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--white);
        margin-bottom: 5px;
    }

    .why-feature-text p {
        font-size: 0.86rem;
        color: var(--text-muted);
        line-height: 1.7;
    }

    /* ══ CTA ══ */
    .cta-section {
        padding: 90px 0;
        background: linear-gradient(135deg, var(--gold-dark) 0%, var(--gold) 50%, var(--gold-light) 100%);
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .cta-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23000' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }

    .cta-section h2 {
        font-size: 2.4rem;
        font-weight: 900;
        color: var(--navy);
        margin-bottom: 14px;
        position: relative;
    }

    .cta-section p {
        font-size: 1.05rem;
        color: rgba(10,22,40,0.75);
        margin-bottom: 36px;
        max-width: 480px;
        margin-left: auto;
        margin-right: auto;
        position: relative;
    }

    .btn-navy {
        background: var(--navy);
        color: var(--gold);
        border: none;
        padding: 14px 38px;
        border-radius: 4px;
        font-family: 'Cairo', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        position: relative;
    }

    .btn-navy:hover {
        background: var(--navy-light);
        transform: translateY(-2px);
        box-shadow: 0 10px 28px rgba(10,22,40,0.35);
        color: var(--gold);
        text-decoration: none;
    }

    /* ══ CONTAINER ══ */
    .container-xl {
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 60px;
    }

    @@media (max-width: 1024px) {
        .services-grid { grid-template-columns: repeat(3, 1fr); }
        .why-grid { grid-template-columns: 1fr; gap: 40px; }
        .hero-stats { display: none; }
    }

    @@media (max-width: 768px) {
        .hero-content { padding: 0 24px; padding-top: 100px; }
        .trips-grid { grid-template-columns: 1fr; max-width: 480px; }
        .services-grid { grid-template-columns: 1fr 1fr; }
        .container-xl { padding: 0 24px; }
    }

    @@media (max-width: 480px) {
        .services-grid { grid-template-columns: 1fr; }
    }
    </style>
}

<!-- ══════════════════════════════════════
     HERO
══════════════════════════════════════ -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>

    <div class="hero-content">
        <div class="hero-badge">
            <i class="fas fa-star"></i>
            وجهتك المثالية تبدأ من هنا
        </div>

        <h1 class="hero-title">
            اكتشف العالم مع<br>
            <span>بلو سكاى</span> للسياحة
        </h1>

        <p class="hero-subtitle">
            رحلات داخلية وخارجية مصممة لك بعناية — حجز فوري، أسعار شفافة، وتجربة سفر لا تُنسى.
        </p>

        <div class="hero-actions">
            <a href="../Home/alltrips?email=@Model.email&triptype=رحلات داخلية" class="btn-gold">
                <i class="fas fa-map-marked-alt" style="margin-left:8px"></i>استكشف الرحلات
            </a>
            <a href="#service" class="btn-outline-gold">تعرف على خدماتنا</a>
        </div>
    </div>

    <div class="hero-stats">
        <div class="stat-item">
            <span class="stat-num">+500</span>
            <div class="stat-label">رحلة منظمة</div>
        </div>
        <div class="stat-item">
            <span class="stat-num">+12K</span>
            <div class="stat-label">عميل سعيد</div>
        </div>
        <div class="stat-item">
            <span class="stat-num">+30</span>
            <div class="stat-label">وجهة سياحية</div>
        </div>
    </div>

    <div class="hero-scroll">
        <i class="fas fa-chevron-down"></i>
        <span>اكتشف أكثر</span>
    </div>
</section>


<!-- ══════════════════════════════════════
     TRIP TYPES
══════════════════════════════════════ -->
<section class="trips-section" id="trips">
    <div class="container-xl">
        <div class="section-header">
            <span class="section-label">وجهاتنا</span>
            <h2 class="section-title">اختر نوع رحلتك</h2>
        </div>

        <div class="trips-grid">
            <a href="../Home/alltrips?email=@Model.email&triptype=رحلات داخلية" class="trip-card">
                <img src="~/files/SiteImages/Riyadh.jpg" alt="رحلات داخلية">
                <div class="trip-card-overlay"></div>
                <div class="trip-card-content">
                    <div class="trip-card-icon"><i class="fas fa-mosque"></i></div>
                    <h3 class="trip-card-title">رحلات داخلية</h3>
                    <p class="trip-card-sub">استكشف أجمل المعالم والوجهات داخل مصر</p>
                    <span class="trip-card-btn">احجز الآن <i class="fas fa-arrow-left"></i></span>
                </div>
            </a>

            <a href="../Home/alltrips?email=@Model.email&triptype=رحلات خارجية" class="trip-card">
                <img src="~/files/SiteImages/slide1.jpg" alt="رحلات خارجية">
                <div class="trip-card-overlay"></div>
                <div class="trip-card-content">
                    <div class="trip-card-icon"><i class="fas fa-plane"></i></div>
                    <h3 class="trip-card-title">رحلات خارجية</h3>
                    <p class="trip-card-sub">سافر إلى أروع الوجهات العالمية بأفضل الأسعار</p>
                    <span class="trip-card-btn">احجز الآن <i class="fas fa-arrow-left"></i></span>
                </div>
            </a>
        </div>
    </div>
</section>


<!-- ══════════════════════════════════════
     SERVICES
══════════════════════════════════════ -->
<section class="services-section" id="service">
    <div class="container-xl">
        <div class="section-header">
            <span class="section-label">ما نقدمه</span>
            <h2 class="section-title">خدماتنا المتميزة</h2>
        </div>

        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon"><i class="fas fa-calendar-check"></i></div>
                <h4 class="service-title">حجز أونلاين</h4>
                <p class="service-desc">احجز رحلتك بسهولة وأمان من أي مكان وفي أي وقت</p>
            </div>

            <div class="service-card">
                <div class="service-icon"><i class="fas fa-search"></i></div>
                <h4 class="service-title">الاستعلامات</h4>
                <p class="service-desc">تتبع حجزك واستعلم عن تفاصيل رحلتك بكل يسر</p>
            </div>

            <div class="service-card">
                <div class="service-icon"><i class="fas fa-clipboard-check"></i></div>
                <h4 class="service-title">مراجعة البيانات</h4>
                <p class="service-desc">راجع وعدّل بياناتك الشخصية وتفاصيل حجزك</p>
            </div>

            <div class="service-card">
                <div class="service-icon"><i class="fas fa-credit-card"></i></div>
