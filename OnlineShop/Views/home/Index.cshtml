                <p class="service-desc">ادفع بأمان عبر بوابات دفع موثوقة ومتعددة</p>
            </div>

            <div class="service-card">
                <div class="service-icon"><i class="fas fa-globe"></i></div>
                <h4 class="service-title">سياحة داخلية وخارجية</h4>
                <p class="service-desc">رحلات متنوعة تلبي أذواق جميع المسافرين</p>
            </div>
        </div>
    </div>
</section>


<!-- ══════════════════════════════════════
     WHY US
══════════════════════════════════════ -->
<section class="why-section" id="about">
    <div class="container-xl">
        <div class="why-grid">
            <div class="why-visual">
                <img src="~/files/SiteImages/Visa-No.03.jpg" alt="لماذا بلو سكاى" class="why-img-main">
