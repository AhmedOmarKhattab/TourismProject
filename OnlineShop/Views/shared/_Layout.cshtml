                    <a href="~/admin/HotelIndex" class="nav-item nav-link">قائمة الفنادق </a>

                </div>
            </div>

        </div>
    </nav>
    @RenderBody()
    <footer>
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 col-12">
