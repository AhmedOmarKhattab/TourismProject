@{
    ViewData["Title"] = "لوحة التحكم - السياحة والحجوزات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>لوحة التحكم السياحية</title>

    @* <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" /> *@

    <style>
       
        .stats-card {
        border: none;
        border-radius: 18px;
        color: white;
        padding: 25px;
        transition: 0.3s;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        }

        .stats-card:hover {
        transform: translateY(-5px);
        }

        .bg-tour {
        background: linear-gradient(135deg, #00b894, #00cec9);
        }

        .bg-booking {
        background: linear-gradient(135deg, #0984e3, #74b9ff);
        }

        .bg-profit {
        background: linear-gradient(135deg, #6c5ce7, #a29bfe);
        }

        .bg-users {
        background: linear-gradient(135deg, #e17055, #fab1a0);
        }

        .chart-card {
        background: white;
        border-radius: 18px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.06);
        }

        .table-card {
        background: white;
        border-radius: 18px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.06);
        }

        h2, h5 {
        font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="container py-4">

        <div class="mb-4">
            <h2>لوحة التحكم السياحية</h2>
            <p class="text-muted">
                مرحباً بك في نظام إدارة الحجوزات والرحلات السياحية
            </p>
        </div>

        <!-- Statistics -->
        <div class="row g-4 mb-5">

            <div class="col-md-3">
                <div class="stats-card bg-tour">
                    <h5>إجمالي الرحلات</h5>
                    <h2>245</h2>
                    <p class="mb-0">رحلة سياحية متاحة</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stats-card bg-booking">
                    <h5>إجمالي الحجوزات</h5>
                    <h2>1,820</h2>
                    <p class="mb-0">حجز خلال هذا الشهر</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stats-card bg-profit">
                    <h5>إجمالي الأرباح</h5>
                    <h2>420,000 ج.م</h2>
                    <p class="mb-0">إيرادات شهرية</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="stats-card bg-users">
                    <h5>عدد العملاء</h5>
                    <h2>5,430</h2>
                    <p class="mb-0">عميل مسجل</p>
                </div>
            </div>

        </div>

        <!-- Charts -->
        <div class="row g-4 mb-5">

            <div class="col-md-8">
                <div class="chart-card">
                    <h5 class="mb-4">إحصائيات الحجوزات الشهرية</h5>
                    <canvas id="bookingChart" height="120"></canvas>
                </div>
            </div>

            <div class="col-md-4">
                <div class="chart-card">
                    <h5 class="mb-4">أكثر الوجهات طلباً</h5>
                    <canvas id="destinationChart"></canvas>
                </div>
            </div>

        </div>

    </div>
        
        <script src="~/lib/charts/chart.js" ></script>
    <script>

        // Monthly Bookings Chart
        const bookingCtx = document.getElementById('bookingChart');

        new Chart(bookingCtx, {
        type: 'line',
        data: {
        labels: ['يناير', 'فبراير', 'مارس', 'أبريل', 'مايو', 'يونيو'],
        datasets: [{
        label: 'عدد الحجوزات',
        data: [120, 190, 300, 500, 420, 610],
        borderColor: '#0984e3',
        backgroundColor: 'rgba(9,132,227,0.2)',
        fill: true,
        tension: 0.4
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: {
        display: true
        }
        }
        }
        });

        // Destination Chart
        const destinationCtx = document.getElementById('destinationChart');

        new Chart(destinationCtx, {
        type: 'doughnut',
        data: {
        labels: ['شرم الشيخ', 'الغردقة', 'إسطنبول', 'دبي'],
        datasets: [{
        data: [35, 25, 20, 20],
        backgroundColor: [
        '#00b894',
        '#0984e3',
        '#6c5ce7',
        '#e17055'
        ]
        }]
        },
        options: {
        responsive: true
        }
        });
    </script>

</body>
</html>