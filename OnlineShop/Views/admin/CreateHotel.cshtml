@model OnlineShop.Dtos.HotelDto

@{
    ViewData["Title"] = "إضافة فندق";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center">إضافة فندق جديد</h2>

<form asp-action="CreateHotel" method="post" enctype="multipart/form-data" dir="rtl">

    <div class="form-group">
        <label>اسم الفندق</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>الوصف</label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>صورة الفندق</label>
        <input asp-for="ImageUrl" type="file" class="form-control" />
        <span asp-validation-for="ImageUrl" class="text-danger"></span>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">إضافة</button>
    <a asp-action="Index" class="btn btn-secondary">رجوع</a>

</form>

}